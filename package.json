{
  "name": "shelf-check",
  "version": "0.1.0",
  "description": "The food industry's accountability report card",
  "private": true,
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "test": "vitest run",
    "collect": "tsx scripts/collect-recalls.ts",
    "analyze": "tsx scripts/analyze-recalls.ts",
    "generate:content": "tsx scripts/generate-content.ts",
    "generate:images": "tsx scripts/generate-images.ts",
    "pipeline": "npm run collect && npm run analyze && npm run generate:content && npm run generate:images",
    "pipeline:deep": "npm run collect && npm run analyze && npm run generate:content -- --deep && npm run generate:images"
  },
  "dependencies": {
    "@analogjs/content": "^2.4.0",
    "@analogjs/router": "^2.4.0",
    "@angular/animations": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/platform-server": "^19.2.0",
    "@angular/router": "^19.2.0",
    "front-matter": "^4.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/platform": "^2.4.0",
    "@analogjs/vite-plugin-angular": "^2.4.0",
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^19.2.0",
    "@types/node": "^22.0.0",
    "sharp": "^0.33.4",
    "tsx": "^4.19.2",
    "typescript": "~5.7.0",
    "vite": "^6.2.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
