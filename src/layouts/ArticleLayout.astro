---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SeverityBadge from '@/components/SeverityBadge.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import DonateCTA from '@/components/DonateCTA.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { formatDate } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  related: CollectionEntry<'articles'>[];
  path: string;
}

const { article, related, path } = Astro.props;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description: article.data.tldr,
  datePublished: article.data.date.toISOString(),
  author: { '@type': 'Organization', name: 'Shelf Check' },
  publisher: { '@type': 'Organization', name: 'Shelf Check' },
};
---
<BaseLayout title={article.data.title} description={article.data.tldr} type="article">
  <article class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_320px]">
      <div>
        <div class="flex flex-wrap items-center gap-4 text-sm text-navy/70">
          <span>{formatDate(article.data.date)}</span>
          <SeverityBadge severity={article.data.severity} />
          <span class="rounded-full bg-paper px-3 py-1 font-semibold uppercase tracking-wide text-navy/70">{article.data.category.replace('-', ' ')}</span>
        </div>
        <h1 class="mt-6 max-w-4xl font-headline text-5xl uppercase leading-none text-navy sm:text-6xl">{article.data.title}</h1>
        <p class="mt-5 max-w-3xl text-lg text-slate-700">{article.data.tldr}</p>

        <div class="mt-8 rounded-3xl border-2 border-amber bg-amber/10 p-6">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-navy/70">Inspector Morsel verdict 🦝</p>
          <p class="mt-3 text-lg font-medium text-navy">{article.data.verdict}</p>
        </div>

        <div class="prose prose-slate mt-10 max-w-none">
          <slot />
        </div>
      </div>

      <aside class="space-y-6">
        <div class="editorial-card rounded-3xl bg-white p-5">
          <p class="font-headline text-2xl uppercase text-navy">Share this report</p>
          <div class="mt-4">
            <ShareButtons title={article.data.title} path={path} />
          </div>
        </div>
        <DonateCTA />
      </aside>
    </div>

    {related.length > 0 && (
      <section class="mt-16">
        <div class="mb-6 flex items-end justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber">Keep digging</p>
            <h2 class="font-headline text-4xl uppercase text-navy">Related articles</h2>
          </div>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {related.map((entry) => <ArticleCard article={entry} />)}
        </div>
      </section>
    )}
  </article>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
</BaseLayout>
