---
interface Props { title?: string; description?: string; image?: string; }
const { title = 'Shelf Check', description = 'The food industry\'s accountability report card.', image } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteUrl = 'https://bullwinkle.js.org/ShelfCheck';
const ogImage = image ? `${siteUrl}/${image}` : `${siteUrl}/images/og-default.png`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Shelf Check 🦝</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={`${title} — Shelf Check 🦝`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} — Shelf Check 🦝`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style is:global>
    :root { --navy: #1a1a2e; --amber: #f0a500; --red: #e63946; --light: #f8f9fa; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; color: #333; background: #fff; line-height: 1.6; }
    h1,h2,h3,h4 { font-family: 'Oswald', sans-serif; }
    a { color: var(--navy); text-decoration: none; }
    a:hover { color: var(--amber); }
    ul, ol { padding-left: 1.5rem; }
    li { margin-bottom: 0.4rem; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1rem; }
    nav { background: var(--navy); padding: 1rem 0; }
    nav .container { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
    nav a { color: #fff; font-family: 'Oswald', sans-serif; font-size: 0.95rem; }
    nav .logo { font-size: 1.4rem; font-weight: 700; white-space: nowrap; }
    nav .links { display: flex; gap: 1.2rem; flex-wrap: wrap; }
    footer { background: var(--navy); color: #aaa; padding: 2rem 0; margin-top: 3rem; text-align: center; font-size: 0.85rem; }
    footer a { color: var(--amber); }
    .hero { background: var(--navy); color: #fff; padding: 3rem 1rem; text-align: center; }
    .hero h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .hero .counter { font-size: 3.5rem; color: var(--amber); font-family: 'Oswald', sans-serif; }
    .hero p { font-size: 1.1rem; opacity: 0.85; max-width: 600px; margin: 0.5rem auto; }
    .badge { display: inline-block; padding: 0.25rem 0.7rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.02em; }
    .badge-red { background: var(--red); color: #fff; }
    .badge-amber { background: var(--amber); color: var(--navy); }
    .badge-green { background: #2a9d8f; color: #fff; }
    .card { background: #fff; border-radius: 8px; padding: 1.5rem; margin-bottom: 1rem; border: 1px solid #e0e0e0; box-shadow: 0 2px 6px rgba(0,0,0,0.08); }
    .card h3 { margin-bottom: 0.5rem; word-break: break-word; }
    .card .meta { font-size: 0.85rem; color: #666; margin-bottom: 0.5rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .verdict { border-left: 4px solid var(--amber); background: #fff8e7; padding: 1rem 1.2rem; margin: 1.5rem 0; border-radius: 0 8px 8px 0; }
    .verdict::before { content: '🦝 Inspector Morsel says:'; display: block; font-family: 'Oswald', sans-serif; font-weight: 600; margin-bottom: 0.3rem; color: var(--navy); }
    section { padding: 2rem 0; }
    article img { max-width: 100%; border-radius: 8px; }
    article h2 { margin: 1.5rem 0 0.5rem; }
    article p { margin-bottom: 1rem; }
    .btn { display: inline-block; padding: 0.6rem 1.4rem; background: var(--amber); color: var(--navy); font-family: 'Oswald', sans-serif; font-weight: 600; border-radius: 6px; font-size: 1rem; }
    .btn:hover { background: #d4940a; color: #fff; }
    @media (max-width: 600px) {
      nav .container { flex-direction: column; text-align: center; gap: 0.6rem; }
      nav .links { justify-content: center; gap: 1rem; font-size: 0.85rem; }
      .hero { padding: 2rem 1rem; }
      .hero h1 { font-size: 1.6rem; line-height: 1.2; }
      .hero .counter { font-size: 2.2rem; }
      .hero p { font-size: 0.95rem; }
      .container { padding: 0 0.75rem; }
      .card { padding: 1.2rem; }
      .grid { grid-template-columns: 1fr; gap: 0.75rem; }
      section { padding: 1.5rem 0; }
      h2 { font-size: 1.3rem; }
    }
  </style>
</head>
<body>
  <nav>
    <div class="container">
      <a href={`${base}/`} class="logo">🦝 Shelf Check</a>
      <div class="links">
        <a href={`${base}/`}>Home</a>
        <a href={`${base}/brands/`}>Brands</a>
        <a href={`${base}/about/`}>About</a>
        <a href={`${base}/support/`}>Support</a>
      </div>
    </div>
  </nav>
  <slot />
  <footer>
    <div class="container">
      <p>🦝 <strong>Shelf Check</strong> — Data from <a href="https://open.fda.gov">openFDA</a>. Analysis by Inspector Morsel.</p>
      <p>Built with data, not opinions. <a href={`${base}/about/`}>Methodology →</a></p>
    </div>
  </footer>
</body>
</html>
