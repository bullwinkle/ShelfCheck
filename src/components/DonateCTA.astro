---
import { SITE } from '@/lib/site';
---
<section class="editorial-card rounded-3xl bg-navy px-6 py-6 text-white">
  <p class="font-headline text-2xl uppercase tracking-wide">Keep the raccoon caffeinated</p>
  <p class="mt-3 text-sm text-white/80">
    Shelf Check stays independent by keeping the data open and the commentary sharp. If this project saves you one sketchy grocery purchase, toss a coin into the evidence bag.
  </p>
  <a href={SITE.donateUrl} class="mt-5 inline-flex rounded-full bg-amber px-5 py-3 text-sm font-bold text-navy">
    Support Shelf Check
  </a>
</section>
