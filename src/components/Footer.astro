---
import { SITE } from '@/lib/site';
import { withBase } from '@/lib/utils';
const year = new Date().getFullYear();
---
<footer class="mt-16 bg-navy text-white">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 sm:px-6 lg:grid-cols-[1.2fr_0.8fr] lg:px-8">
    <div>
      <p class="font-headline text-3xl uppercase tracking-wide">Shelf Check</p>
      <p class="mt-3 max-w-2xl text-sm text-white/75">
        {SITE.mascot} tracks recalls, repeat offenders, and the patterns food brands would rather leave under the shelf liner.
      </p>
    </div>
    <div class="grid gap-2 text-sm text-white/80">
      <a href={withBase('about')} class="hover:text-amber">Methodology</a>
      <a href={withBase('support')} class="hover:text-amber">Support the project</a>
      <a href={withBase('rss.xml')} class="hover:text-amber">RSS feed</a>
      <a href="https://github.com/bullwinkle/ShelfCheck" class="hover:text-amber">GitHub repo</a>
    </div>
  </div>
  <div class="border-t border-white/10 px-4 py-4 text-center text-xs text-white/60">
    © {year} Shelf Check. Data sourced from FDA enforcement reports.
  </div>
</footer>
