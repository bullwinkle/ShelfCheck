---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BrandScoreCard from '@/components/BrandScoreCard.astro';
import { getBrands } from '@/lib/data';

const brands = getBrands().sort((a, b) => b.accountability_score - a.accountability_score).slice(0, 24);
---
<BaseLayout title="Brand Reports" description="Shelf Check brand accountability scores based on frequency, severity, speed, and scope.">
  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber">Brand reports</p>
    <h1 class="mt-3 font-headline text-5xl uppercase text-navy">Who keeps fumbling the pantry.</h1>
    <p class="mt-4 max-w-3xl text-lg text-slate-700">Accountability Scores weigh frequency, severity, response speed, and geographic scope. Higher numbers mean warmer danger colors and colder confidence.</p>
    <div class="mt-10 grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
      {brands.map((brand) => <BrandScoreCard brand={brand} />)}
    </div>
  </section>
</BaseLayout>
