---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import RecallCounter from '@/components/RecallCounter.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import BrandScoreCard from '@/components/BrandScoreCard.astro';
import TrendChart from '@/components/TrendChart';
import { getBrands, getStats } from '@/lib/data';
import { withBase } from '@/lib/utils';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latestArticles = articles.slice(0, 6);
const worstBrands = getBrands().sort((a, b) => b.accountability_score - a.accountability_score).slice(0, 5);
const stats = getStats();
const months = Object.entries(stats.monthly_breakdown)
  .sort(([a], [b]) => a.localeCompare(b))
  .slice(-12);
const labels = months.map(([month]) => `${month.slice(0, 4)}-${month.slice(4)}`);
const values = months.map(([, count]) => count);
---
<BaseLayout title="Home" description="Shelf Check tracks FDA food recalls, repeat offenders, and trend lines that matter.">
  <section class="bg-navy text-white">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 lg:grid-cols-[minmax(0,1fr)_320px] lg:px-8 lg:py-20">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-amber">Food recall intelligence</p>
        <h1 class="mt-5 max-w-4xl font-headline text-6xl uppercase leading-none sm:text-7xl">
          The grocery aisle's least flattering audit.
        </h1>
        <div class="mt-8 flex items-end gap-4">
          <RecallCounter value={stats.total_recalls_this_year} />
          <p class="max-w-xs pb-2 text-sm uppercase tracking-[0.2em] text-white/70">recalls in 2026 so far</p>
        </div>
        <p class="mt-6 max-w-2xl text-lg text-white/80">
          Inspector Morsel keeps score so the labels can't hide behind cheerful packaging.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={withBase('daily-digest')} class="rounded-full bg-amber px-5 py-3 text-sm font-bold text-navy">Read the digest</a>
          <a href={withBase('brands')} class="rounded-full border border-white/20 px-5 py-3 text-sm font-bold text-white">See worst offenders</a>
        </div>
      </div>
      <aside class="rounded-3xl border border-white/10 bg-white/5 p-6">
        <p class="font-headline text-2xl uppercase text-white">Worst offenders</p>
        <div class="mt-5 space-y-4">
          {worstBrands.map((brand) => (
            <div class="rounded-2xl bg-white/5 p-4">
              <div class="flex items-center justify-between gap-3">
                <p class="font-semibold text-white">{brand.brand_name}</p>
                <span class="rounded-full bg-danger px-3 py-1 text-[10px] font-bold uppercase tracking-wide text-white">{brand.grade}</span>
              </div>
              <p class="mt-2 text-sm text-white/70">{brand.total_recalls} recalls · {brand.class_i_recalls} Class I · score {brand.accountability_score}</p>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber">Coverage lanes</p>
        <h2 class="font-headline text-4xl uppercase text-navy">Latest stories</h2>
      </div>
      <div class="flex flex-wrap gap-2 text-sm font-semibold">
        <a href={withBase('daily-digest')} class="rounded-full bg-paper px-4 py-2 text-navy">Daily Digest</a>
        <a href={withBase('deep-dives')} class="rounded-full bg-paper px-4 py-2 text-navy">Deep Dives</a>
        <a href={withBase('brands')} class="rounded-full bg-paper px-4 py-2 text-navy">Brand Reports</a>
      </div>
    </div>
    <div class="mt-8 grid gap-6 xl:grid-cols-3 md:grid-cols-2">
      {latestArticles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <section class="bg-paper">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[minmax(0,1fr)_360px] lg:px-8">
      <div class="editorial-card rounded-3xl bg-white p-6">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber">Trend line</p>
        <h2 class="font-headline text-4xl uppercase text-navy">Recall velocity</h2>
        <p class="mt-3 max-w-2xl text-sm text-slate-600">Client-side Chart.js island, because static pages can still arrive with a pulse.</p>
        <div class="mt-6">
          <TrendChart client:load title="Monthly recall count" labels={labels} values={values} />
        </div>
      </div>
      <div class="space-y-5">
        {worstBrands.slice(0, 2).map((brand) => <BrandScoreCard brand={brand} compact />)}
      </div>
    </div>
  </section>
</BaseLayout>
