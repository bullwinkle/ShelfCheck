---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrendChart from '@/components/TrendChart';
import { getStats } from '@/lib/data';

const stats = getStats();
const categories = Object.entries(stats.category_breakdown).sort((a, b) => b[1] - a[1]).slice(0, 6);
---
<BaseLayout title="About" description="Shelf Check methodology, scoring model, and editorial rules.">
  <section class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber">About Shelf Check</p>
    <h1 class="mt-3 font-headline text-5xl uppercase text-navy">The method behind the snark.</h1>
    <div class="prose prose-slate mt-8 max-w-none">
      <p>Shelf Check ingests FDA food enforcement records, deduplicates them by recall number, then calculates brand Accountability Scores. The weights are simple on purpose: frequency 30%, severity 30%, response speed 20%, scope 20%.</p>
      <p>Class I recalls hit hardest, national distribution pushes risk upward, and repeat offenders get flagged when they rack up three or more recalls inside a rolling 365-day window.</p>
      <p>Inspector Morsel's commentary is generated from those numbers, then saved as markdown content that can be edited in the admin panel before publication.</p>
    </div>
    <div class="editorial-card mt-10 rounded-3xl bg-white p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-amber">Category pressure</p>
      <h2 class="font-headline text-4xl uppercase text-navy">What keeps showing up</h2>
      <div class="mt-6">
        <TrendChart client:load title="Top recall categories" labels={categories.map(([label]) => label)} values={categories.map(([, count]) => count)} color="#e63946" />
      </div>
    </div>
  </section>
</BaseLayout>
